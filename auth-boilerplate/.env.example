# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://...

# Better Auth (generate with: npx @better-auth/cli secret)
BETTER_AUTH_SECRET=your-secret-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxx
# Dev: use onboarding@resend.dev (only delivers to your Resend account email)
# Prod: verify your domain and use e.g. noreply@yourdomain.com
SMTP_FROM=Auth Boilerplate <onboarding@resend.dev>

# Optional: Google OAuth (remove socialProviders block if not using)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
